{
  "name": "tabiji",
  "type": "module",
  "version": "0.0.3",
  "description": "Type safe Testing Library",
  "author": "kazeusagi",
  "license": "MIT",
  "homepage": "https://github.com/kazeusagi/tabiji#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kazeusagi/tabiji.git"
  },
  "bugs": {
    "url": "https://github.com/kazeusagi/tabiji/issues"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "exec": "bun dist/index.mjs",
    "test:vitest": "vitest ./test/vitest.test.ts",
    "test:bun": "bun test ./test/bun.test.ts",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "prepublishOnly": "bun run build",
    "docs:dev": "vitepress dev",
    "docs:build": "vitepress build",
    "docs:preview": "vitepress preview"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.6.2",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "bumpp": "^11.1.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vitepress": "^2.0.0-alpha.17",
    "vitest": "^4.1.5"
  }
}